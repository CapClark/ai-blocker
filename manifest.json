{
  "manifest_version": 3,
  "name": "AI Blocker",
  "version": "0.1.0",
  "description": "Hide AI product surfaces (AI Overviews, Copilot answers, Grok, Meta AI…) and flag declared AI media.",
  "author": "CapClark",
  "homepage_url": "https://github.com/CapClark/ai-blocker",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "declarativeNetRequest", "offscreen", "alarms", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "AI Blocker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": false,
      "js": [
        "src/shared/constants.js",
        "src/content/filters/cosmetic-filters.js",
        "src/content/filters/slop-domains.js",
        "src/content/engine.js",
        "src/content/media-scanner.js",
        "src/content/content.js"
      ]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "ai-endpoints", "enabled": true, "path": "rules/dnr.json" }
    ]
  }
}
